# === Attentiveness Tracker Configuration ===

# Roboflow API (REQUIRED)
ROBOFLOW_API_KEY=your_api_key_here
ROBOFLOW_PROJECT=attention50k
ROBOFLOW_VERSION=3

# Flask
SECRET_KEY=attentiveness-tracker-2026-secret
DEBUG=False

# Database
DATABASE_NAME=attentiveness.db

# Detection Tuning
CONFIDENCE_THRESHOLD=40
OVERLAP_THRESHOLD=30
SMOOTHING_WINDOW=5
ALERT_CONSECUTIVE_FRAMES=3
BLUR_THRESHOLD=15.0
