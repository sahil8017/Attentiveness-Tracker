# === Attentiveness Tracker Configuration ===

# Roboflow API (REQUIRED)
ROBOFLOW_API_KEY=your-roboflow-api-key-here
ROBOFLOW_PROJECT=attention50k
ROBOFLOW_VERSION=3

# Database — PostgreSQL (REQUIRED)
# For Docker Compose, this is overridden by the compose environment
DATABASE_URL=postgresql://attentiveness:attentiveness_dev@localhost:5432/attentiveness

# Authentication
SECRET_KEY=change-me-to-a-random-string
JWT_SECRET_KEY=change-me-to-a-random-string
JWT_EXPIRY_HOURS=24

# App Settings
DEBUG=false

# Detection Tuning
CONFIDENCE_THRESHOLD=40
OVERLAP_THRESHOLD=30
SMOOTHING_WINDOW=5
ALERT_CONSECUTIVE_FRAMES=3
BLUR_THRESHOLD=15.0
